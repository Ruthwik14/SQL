\par     customer_id,
\par     first_name,
\par     last_name,
\par     billing_country,
\par     total_spent
\par FROM (
\par     SELECT 
\par         c.customer_id,
\par         c.first_name,
\par         c.last_name,
\par         i.billing_country,
\par         SUM(i.total) AS total_spent,
\par         ROW_NUMBER() OVER (PARTITION BY i.billing_country ORDER BY SUM(i.total) DESC) AS row_num
\par     FROM 
\par         invoice i
\par     JOIN 
\par         customer c ON c.customer_id = i.customer_id
\par     GROUP BY 
\par         1, 2, 3, 4
\par ) AS abc
\par WHERE 
\par     row_num = 1;}{\rtlch\fcs1 \af0 \ltrch\fcs0 \cf20\insrsid14832555 
