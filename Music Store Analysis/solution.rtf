\par }\pard \ltrpar\ql \li0\ri0\widctlpar\wrapdefault\aspalpha\aspnum\faauto\adjustright\rin0\lin0\itap0\pararsid6907719 {\rtlch\fcs1 \af0 \ltrch\fcs0 \cf20\insrsid6907719\charrsid6907719 SELECT a.name, COUNT(t.track_id) AS total_count 
\par FROM artist a 
\par JOIN album al ON a.ArtistID = al.Artist_ID
\par JOIN track t ON al.album_id = t.album_id
\par WHERE t.genre_id IN (
\par     SELECT genre_id 
\par     FROM genre
\par     WHERE name LIKE 'Rock'
\par )
\par GROUP BY a.name
\par ORDER BY total_count DESC
\par LIMIT 10;}{\rtlch\fcs1 \af0 \ltrch\fcs0 \cf20\insrsid9333176 
